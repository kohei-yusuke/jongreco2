// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GameStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  salt      String?   @default(dbgenerated("gen_random_uuid()"))
  name      String?
  iconPath  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  players   Player[]
  sentFriendRequests     FriendRequest[] @relation("SentFriendRequests")
  receivedFriendRequests FriendRequest[] @relation("ReceivedFriendRequests")
  friends                Friend[]        @relation("UserFriends")
  friendOf               Friend[]        @relation("FriendOf")
}

model Game {
  id              String    @id @default(cuid())
  name            String?
  initialPoints   Int       @default(25000)
  returnPoints    Int       @default(30000)
  chipPoints      Int       @default(1000)
  yakitoriPoints  Int       @default(6000)
  yakitoriMode    String    @default("distribution") // "distribution" | "winner_takes_all"
  uma1            Int       @default(10)
  uma2            Int       @default(5)
  uma3            Int       @default(-5)
  uma4            Int       @default(-10)
  chipEnabled     Boolean   @default(true)
  yakitoriEnabled Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  players         Player[]
  scores          Score[]
  history         GameHistory?
  rounds          Round[]
  status          GameStatus @default(IN_PROGRESS)
}

model Player {
  id        String   @id @default(cuid())
  gameId    String
  userId    String?
  name      String
  position  String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  history   GameHistoryPlayer[]

  @@index([gameId])
  @@index([userId])
}

model Score {
  id        String   @id @default(cuid())
  gameId    String
  round     Int
  east      Int
  south     Int
  west      Int
  north     Int
  yakitori  Yakitori?
  game      Game     @relation(fields: [gameId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  roundId   String?
  roundRelation Round?   @relation(fields: [roundId], references: [id])

  @@index([gameId])
}

model Yakitori {
  id      String @id @default(cuid())
  scoreId String @unique
  east    Boolean @default(false)
  south   Boolean @default(false)
  west    Boolean @default(false)
  north   Boolean @default(false)
  score   Score  @relation(fields: [scoreId], references: [id])
}

model GameHistory {
  id        String   @id @default(cuid())
  gameId    String   @unique
  game      Game     @relation(fields: [gameId], references: [id])
  status    String   @default("draft") // draft, completed
  players   GameHistoryPlayer[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gameId])
}

model GameHistoryPlayer {
  id            String      @id @default(cuid())
  gameHistoryId String
  gameHistory   GameHistory @relation(fields: [gameHistoryId], references: [id])
  playerId      String
  player        Player      @relation(fields: [playerId], references: [id])
  name          String
  totalScore    Int
  rank          Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([gameHistoryId])
  @@index([playerId])
}

model FriendRequest {
  id        String   @id @default(cuid())
  fromId    String
  toId      String
  status    String   @default("pending") // pending, accepted, rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  from      User     @relation("SentFriendRequests", fields: [fromId], references: [id])
  to        User     @relation("ReceivedFriendRequests", fields: [toId], references: [id])

  @@unique([fromId, toId])
  @@index([fromId])
  @@index([toId])
}

model Friend {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation("UserFriends", fields: [userId], references: [id])
  friend    User     @relation("FriendOf", fields: [friendId], references: [id])

  @@unique([userId, friendId])
  @@index([userId])
  @@index([friendId])
}

model Round {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  game      Game     @relation(fields: [gameId], references: [id])
  gameId    String
  number    Int      // 局数
  scores    Score[]  // 各プレイヤーの点数
  chipPoints Int?    // チップの点数（設定されている場合）
}
